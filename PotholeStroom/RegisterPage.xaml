<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PotholeStroom.RegisterPage"
             Title="Authentication">

    <VerticalStackLayout Padding="30" Spacing="15">

        <Label Text="Email" FontAttributes="Bold" />
        <Entry x:Name="emailEntry" Placeholder="Enter your email" Keyboard="Email" />

        <Label Text="Password" FontAttributes="Bold" />
        <Entry x:Name="passwordEntry" Placeholder="Enter your password" IsPassword="True" />

        <Button Text="Sign Up" Clicked="OnSignUpClicked" />
        <Button Text="Sign In" Clicked="OnSignInClicked" />

        <Label x:Name="messageLabel" TextColor="Red" FontSize="14" />

    </VerticalStackLayout>
</ContentPage>
